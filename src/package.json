{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc && vite build && vite build --ssr",
        "dev": "vite",
        "lint": "eslint resources/js --ext .ts,.tsx",
        "lint:fix": "eslint resources/js --ext .ts,.tsx --fix",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"resources/js/**/*.{ts,tsx}\"",
        "format:check": "prettier --check \"resources/js/**/*.{ts,tsx}\""
    },
    "devDependencies": {
        "@eslint/js": "^9.22.0",
        "@headlessui/react": "^2.2.4",
        "@inertiajs/react": "^2.2.15",
        "@tailwindcss/forms": "^0.5.10",
        "@types/node": "^22.15.17",
        "@types/react": "^18.3.23",
        "@types/react-dom": "^18.3.7",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@vitejs/plugin-react": "^5.0.4",
        "autoprefixer": "^10.4.21",
        "axios": "^1.12.2",
        "concurrently": "^9.2.1",
        "eslint": "^9.22.0",
        "eslint-plugin-react": "^7.37.4",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^15.14.0",
        "laravel-vite-plugin": "^3.0.1",
        "postcss": "^8.5.6",
        "prettier": "^3.5.0",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tailwindcss": "^3.4.18",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.22.0",
        "vite": "^8.0.8"
    },
    "dependencies": {
        "@xyflow/react": "^12.8.5"
    }
}
